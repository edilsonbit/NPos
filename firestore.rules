rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Regra de homologacao/demo para permitir o portal ler e gravar os cupons.
    // Em producao, restrinja com Firebase Auth ou regras por contexto.
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
